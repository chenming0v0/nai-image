# ==========================================
# NAI Image Client - Docker Compose 配置
# ==========================================

# 后端端口
BACKEND_PORT=8787

# 前端端口
FRONTEND_PORT=8080

# ==========================================
# 上游 NovelAI 接口配置
# ==========================================

# 公益站提供的 NewAPI 地址（例如：https://api.example.com/v1）
UPSTREAM_BASE_URL=

# 公益站提供的 API 密钥
UPSTREAM_API_KEY=

# 默认模型
# 可选值：
#   - nai-diffusion-4-5-full
#   - nai-diffusion-4-5-curated
#   - nai-diffusion-4-full
#   - nai-diffusion-4-curated
#   - nai-diffusion-3
#   - nai-diffusion-furry-3
DEFAULT_MODEL=nai-diffusion-4-5-full

# ==========================================
# 后端高级配置（可选）
# ==========================================

# 请求超时时间（秒）
REQUEST_TIMEOUT_SECONDS=180

# 最大图片大小（字节，默认 512MB）
MAX_IMAGE_BYTES=536870912
