{
  "name": "nai-image-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd backend && go run ./cmd/server",
    "dev:frontend": "vite",
    "dev:all": "concurrently -n \"backend,frontend\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "npm run dev:all",
    "mock:api": "node scripts/mock-image-api.mjs",
    "build": "tsc -b && vite build",
    "build:backend": "cd backend && go build -o ../dist/nai-backend ./cmd/server",
    "build:all": "npm run build && npm run build:backend",
    "deploy:cf": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.0",
    "@streamdown/math": "^1.0.2",
    "core-js": "^3.49.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.40.0",
    "katex": "^0.16.47",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "zustand": "^5.0.5"
  },
  "overrides": {
    "mdast-util-gfm-autolink-literal": "2.0.0",
    "dompurify": "^3.4.7"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.96.0"
  }
}
